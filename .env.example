# Microsoft Graph
# Your values come from the app registration in Azure Portal.
GRAPH_CLIENT_ID=...
GRAPH_TENANT_ID=...

# Scopes separated by spaces
GRAPH_SCOPES=Files.ReadWrite.All offline_access

# Path to your training file in OneDrive, e.g. /Documents/Marathon/TrainingProgram.xlsx
GRAPH_EXCEL_PATH=/Path/To/Your/TrainingFile.xlsx

# Name of the worksheet where the log should be stored
GRAPH_LOG_SHEET_NAME=Logg

# Where the token cache file should be stored (locally on the Pi or host)
GRAPH_TOKEN_CACHE_PATH=graph_token_cache.bin


# Strava
STRAVA_CLIENT_ID=YOUR_STRAVA_CLIENT_ID
STRAVA_CLIENT_SECRET=YOUR_STRAVA_CLIENT_SECRET
STRAVA_REFRESH_TOKEN=YOUR_STRAVA_REFRESH_TOKEN


# State/runtime
# Start date from which activities should be included (ISO format, local time is fine)
TRAINING_START_DATE=2026-03-01
TEMP_EXCEL_PATH=local_training.xlsx


# Telegram (optional – for run success/failure notifications to your phone)
# TELEGRAM_BOT_TOKEN=...
# TELEGRAM_CHAT_ID=...

# Plan summary in Telegram (optional – sheet with formulas, cells to read)
# PLAN_AGG_SHEET=Plan+Agg
# PLAN_AGG_SUMMARY=B2:Vecka,B3:Återstående volym (min),B4:Återstående pass
# PLAN_AGG_WAIT_SECONDS=3

