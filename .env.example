# Microsoft Graph
# Dina värden kommer från app-registreringen i Azure Portal.
GRAPH_CLIENT_ID=...
GRAPH_TENANT_ID=...

# Scopes separerade med mellanslag
GRAPH_SCOPES=Files.ReadWrite.All offline_access

# Sökvägen till din träningsfil i OneDrive, t.ex. /Documents/Marathon/Träningsprogram.xlsx
GRAPH_EXCEL_PATH=/Path/To/Your/TrainingFile.xlsx

# Namn på fliken där loggen ska ligga
GRAPH_LOG_SHEET_NAME=Logg

# Var token-cachen ska sparas (lokalt på Pi:n)
GRAPH_TOKEN_CACHE_PATH=graph_token_cache.bin


# Strava
STRAVA_CLIENT_ID=YOUR_STRAVA_CLIENT_ID
STRAVA_CLIENT_SECRET=YOUR_STRAVA_CLIENT_SECRET
STRAVA_REFRESH_TOKEN=YOUR_STRAVA_REFRESH_TOKEN


# State/runtime
# Startdatum för vilka löppass som ska tas med (ISO-format, lokal tid ok)
TRAINING_START_DATE=2026-03-01
TEMP_EXCEL_PATH=local_training.xlsx

